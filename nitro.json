{
  "cxxNamespace": ["rnswiftui"],
  "ios": {
    "iosModuleName": "RNSwiftUI"
  },
  "android": {
    "androidNamespace": ["rnswiftui"],
    "androidCxxLibName": "RNSwiftUI"
  },
  "autolinking": {
    "SFSymbolView": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridSFSymbolView"
      }
    },
    "PickerView": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridPickerView"
      }
    },
    "SheetView": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridSheetView"
      }
    },
    "SheetPickerView": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridSheetPickerView"
      }
    },
    "SwiftUIRootView": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridSwiftUIRootView"
      }
    }
  },
  "ignorePaths": ["node_modules", "example", ".idea"]
}
