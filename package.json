{
  "name": "@mgcrea/react-native-swiftui",
  "version": "0.16.0",
  "description": "SwiftUI components for React Native",
  "author": "Olivier Louvignes <olivier@mgcrea.io> (https://github.com/mgcrea)",
  "homepage": "https://github.com/mgcrea/react-native-swiftui#readme",
  "repository": "github:mgcrea/react-native-swiftui",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "*.podspec",
    "nitro.json",
    "src",
    "dist",
    "ios",
    "nitrogen/generated"
  ],
  "scripts": {
    "dev": "cd example; npm run dev",
    "build": "npm run build:babel && npm run build:types && npm run nitrogen",
    "build:babel": "babel src --out-dir dist --extensions \".ts,.tsx,.js,.jsx\" --copy-files",
    "build:types": "tsc --emitDeclarationOnly && tsc-alias",
    "install:ios": "cd example; npm run install:ios",
    "open:ios": "cd example; npm run open:ios",
    "nitrogen": "npx nitrogen",
    "lint": "oxlint src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "check": "tsc --noEmit",
    "spec": "NODE_OPTIONS=--experimental-require-module jest",
    "test": "npm run lint && npm run check && npm run spec",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.9",
    "@babel/runtime": "^7.26.9",
    "@jest/globals": "^29.7.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.0.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "^29.7.0",
    "nitrogen": "^0.35.5",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "react-native-nitro-modules": "^0.35.5",
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-test-renderer": "19.2.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.2"
}